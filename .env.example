# ── MongoDB Atlas ──────────────────────────────────────────────────────────────
# Crée un cluster gratuit sur https://cloud.mongodb.com
# Puis : Database > Connect > Drivers > copie la connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/reactioncam?retryWrites=true&w=majority

# ── Cloudinary ─────────────────────────────────────────────────────────────────
# Crée un compte gratuit sur https://cloudinary.com
# Puis : Dashboard > copie les 3 valeurs
CLOUDINARY_CLOUD_NAME=ton_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ── Session ───────────────────────────────────────────────────────────────────
# Génère une valeur aléatoire forte (ex: openssl rand -base64 32)
SESSION_SECRET=change_moi_avec_une_valeur_secrete_longue

# ── MongoDB Atlas ──────────────────────────────────────────────────────────────
# Crée un cluster sur https://cloud.mongodb.com
# Database > Connect > Drivers > copie la connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/reactioncam?retryWrites=true&w=majority

# ── Cloudinary ─────────────────────────────────────────────────────────────────
# Compte sur https://cloudinary.com — Dashboard > 3 valeurs
CLOUDINARY_CLOUD_NAME=ton_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ── Session (REQUIS en prod) ──────────────────────────────────────────────────
# Génère : openssl rand -base64 48
SESSION_SECRET=change_moi_avec_une_valeur_secrete_longue_min_32_chars

# ── Admin (REQUIS en prod) ────────────────────────────────────────────────────
# Liste d'emails admin séparés par des virgules
ADMIN_EMAILS=admin@reaction-cam.com

# ── Stripe (REQUIS pour activer le paiement) ──────────────────────────────────
# Dashboard Stripe > Developers > API keys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxx
# Dashboard Stripe > Webhooks > Endpoint > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx
# Dashboard Stripe > Products > Pro 5€/mois > Price ID
STRIPE_PRICE_ID=price_xxxxxxxxxxxxx

# ── Resend (emails transactionnels) ───────────────────────────────────────────
# https://resend.com — sans cette clé, les liens de vérif sont loggés (dev)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx

# ── Google OAuth (optionnel) ──────────────────────────────────────────────────
# https://console.cloud.google.com — OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://reaction-cam.com/auth/google/callback

# ── Admin cleanup endpoint (optionnel) ────────────────────────────────────────
# Header X-Admin-Key pour POST /api/admin/cleanup sans session
ADMIN_KEY=

# ── Observabilité (optionnel mais recommandé en prod) ─────────────────────────
# Sentry — créer un projet Node sur https://sentry.io et coller le DSN.
# Sans valeur, l'instrumentation est désactivée et n'a aucun coût runtime.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0

# Niveau de log pino : debug | info | warn | error (défaut info en prod, debug en dev)
LOG_LEVEL=

# ── Render auto-set ───────────────────────────────────────────────────────────
# RENDER=true (auto), NODE_ENV=production
